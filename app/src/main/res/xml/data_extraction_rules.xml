<?xml version="1.0" encoding="utf-8"?>
<!--
    Explicitly exclude all data from backup to prevent PINs leaking
    through Google Backup or ADB backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
